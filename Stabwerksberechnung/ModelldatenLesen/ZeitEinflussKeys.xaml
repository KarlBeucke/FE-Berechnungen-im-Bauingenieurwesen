<Window x:Class="FE_Berechnungen.Stabwerksberechnung.ModelldatenLesen.ZeitEinflussKeys"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="vorhandene dynamische Modelleinflüsse" Height="250" Width="300">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition Height="80" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>
        <Label Grid.Column="0" Grid.Row="0" Margin="0,-6,0,0">zeitabhängige Knotenlasten</Label>
        <ListView Grid.Row="0" Width="300" Margin="0,15,0,0" Name="ZeitlastenKeys" d:DataContext="{d:DesignData modell}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="LastID" Width="70" DisplayMemberBinding="{Binding LastId}" />
                    <GridViewColumn Header="Knoten" Width="70" DisplayMemberBinding="{Binding KnotenId}" />
                </GridView>
            </ListView.View>
        </ListView>
        <Label Grid.Column="0" Grid.Row="1" Margin="0,-6,0,0">Anfangsbedingungen</Label>
        <ListView Grid.Row="1" Width="300" Margin="0,17,0,0" Name="ZeitAnfangKeys" d:DataContext="{d:DesignData modell}">
            <ListView.View><GridView>
                    <GridViewColumn Header="Knoten" Width="70" DisplayMemberBinding="{Binding KnotenId}" />
                </GridView>
            </ListView.View>
        </ListView>
        <Button Height="18" Margin="200,0,20,0" VerticalAlignment="Top"
                Click="BtnDialogCancel_Click" Grid.Row="2">
            _schließen
        </Button>
    </Grid>
</Window>