<Window x:Class="FE_Berechnungen.BerechnungsdatenAnzeigen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="BerechnungsdatenAnzeigen" Height="300" Width="800">
    <Grid>
        <DataGrid HorizontalAlignment="Left" VerticalAlignment="Top"
                  Name="MatrixGrid" Width="500" Margin="10,10,0,0">
        </DataGrid>
        <DataGrid HorizontalAlignment="Left" VerticalAlignment="Top"
                  Name="VektorGrid" Width="50" Margin="550,10,0,0">
        </DataGrid>

        <DataGrid HorizontalAlignment="Left" VerticalAlignment="Top"
                  Name="PrimalGrid" Width="50" Margin="630,10,0,0">
        </DataGrid>

        <DataGrid HorizontalAlignment="Left" VerticalAlignment="Top"
                  Name="DualGrid" Width="50" Margin="700,10,0,0">
        </DataGrid>
    </Grid>
</Window>
